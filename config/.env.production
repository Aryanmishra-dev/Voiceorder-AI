# Production configuration template.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=cakebot
DATABASE_URL=postgresql+asyncpg://postgres:replace-with-strong-postgres-password@db:5432/cakebot

OPENAI_API_KEY=replace-with-openrouter-key
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

ADMIN_API_KEY=replace-with-long-random-api-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

ENABLE_WEBHOOK_VALIDATION=true
WEBHOOK_TIMEOUT_SECONDS=30

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_IDENTIFIERS=10000

CORS_ALLOWED_ORIGINS=https://your-domain.example
TRUSTED_HOSTS=your-domain.example
ENABLE_HSTS=true
LOG_PII=false

LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.7
LLM_EXTRACTION_TEMPERATURE=0.0
LLM_MAX_TOKENS=300

LOG_LEVEL=INFO
DEBUG=false
