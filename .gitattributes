# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Markdown
*.md text eol=lf

# YAML/JSON
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Config
*.cfg text eol=lf
*.conf text eol=lf
*.ini text eol=lf
.env* text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Documentation
*.txt text eol=lf
*.rst text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.sqlite binary
*.db binary
